{
  "description": "frugal enforcement — keep frugal-mode instructions warm and nudge before inline edits; both gated on .claude/frugal/active, inert otherwise",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/frugal-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/frugal-nudge.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
