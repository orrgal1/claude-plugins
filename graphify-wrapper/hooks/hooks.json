{
  "description": "On session start: seed missing domain graphs from the main worktree, and AST-refresh any graph whose built_at_commit has drifted from HEAD. Both background, never build semantically.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/seed-worktree.sh",
            "statusMessage": "graphify-wrapper: checking worktree graphs"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/refresh-stale.sh",
            "statusMessage": "graphify-wrapper: checking graph freshness"
          }
        ]
      }
    ]
  }
}
